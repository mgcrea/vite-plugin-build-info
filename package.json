{
  "name": "@mgcrea/vite-plugin-build-info",
  "version": "0.3.0",
  "description": "Vite plugin that exposes build information (git commit hash, branch, etc.) as a global variable",
  "author": "Olivier Louvignes <olivier@mgcrea.io> (https://github.com/mgcrea)",
  "homepage": "https://github.com/mgcrea/vite-plugin-build-info#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mgcrea/vite-plugin-build-info.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "git",
    "commit",
    "version",
    "build-info"
  ],
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.33.0"
}
